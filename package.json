{
  "name": "cml-project-gallery",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.17.0",
  "description": "Prototype gallery of CML software and data projects (proposal-stage, not an official CML site).",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "node --test 'src/**/*.test.ts'",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info --test-reporter=spec --test-reporter-destination=stdout 'src/**/*.test.ts'",
    "ingest": "node scripts/fetch-github-projects.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@fontsource/dm-mono": "^5.1.0",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.2",
    "typescript": "^5.9.3"
  }
}
